# The Docker Compose setup works with these local defaults.
NODE_ENV=production
PORT=3000
APP_ID=local
APP_SECRET=change-this-for-a-shared-deployment
DATABASE_URL=mysql://poker:poker@db:3306/poker_room

# MySQL container settings
MYSQL_DATABASE=poker_room
MYSQL_USER=poker
MYSQL_PASSWORD=poker
MYSQL_ROOT_PASSWORD=change-this-root-password
